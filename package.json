{
  "name": "intools-components",
  "version": "1.0.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/crypto-id/sro-intools-fe.git"
  },
  "publishConfig": {
    "access": "restricted",
    "registry": "https://registry.npmjs.org"
  },
  "packageManager": "yarn@4.12.0",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "run-s clean build:core",
    "build-storybook": "storybook build",
    "build:core": "run-p build:swc build:tsc",
    "build:swc": "swc src -d dist --copy-files --strip-leading-paths",
    "build:tsc": "tsc --build --emitDeclarationOnly && echo 'TypeScript build completed'",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "dev": "run-s build:core",
    "lint": "eslint \"src/**/*.{js,jsx,ts,tsx}\"",
    "lint:fix": "eslint --fix \"src/**/*.{js,jsx,ts,tsx}\"",
    "storybook": "storybook dev -p 6006",
    "test": "jest",
    "test:coverage-badges": "jest-coverage-badges",
    "type-check": "tsc --noEmit"
  },
  "peerDependencies": {
    "@emotion/react": ">=11",
    "@emotion/styled": ">=11",
    "framer-motion": ">=10",
    "polished": ">=4",
    "react": ">=18",
    "react-dom": ">=18",
    "react-icons": ">=5",
    "recharts": ">=3"
  },
  "dependencies": {
    "@chakra-ui/icons": "2.2.6",
    "@chakra-ui/react": "2.10.7",
    "@chakra-ui/react-context": "2.1.0",
    "@chakra-ui/utils": "2.2.2",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "lodash-es": "^4.18.1",
    "react-dnd": "14.0.3",
    "react-dnd-html5-backend": "14.0.1",
    "react-dnd-touch-backend": "14.1.0",
    "react-fast-compare": "3.2.2",
    "react-virtuoso": "4.18.5"
  },
  "devDependencies": {
    "@emotion/jest": "11.14.2",
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.0",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-onboarding": "^10.3.5",
    "@storybook/nextjs-vite": "^10.3.5",
    "@swc/cli": "^0.7.3",
    "@swc/core": "^1.11.21",
    "@swc/plugin-emotion": "^14.8.0",
    "@swc/plugin-react-remove-properties": "^12.8.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/identity-obj-proxy": "^3",
    "@types/jest": "^29.0.0",
    "@types/lodash": "^4.17.24",
    "@types/lodash-es": "^4.17.12",
    "@types/nprogress": "^0.2.1",
    "@types/react": "18.2.25",
    "@types/react-datepicker": "4.15.1",
    "@types/react-dom": "18.2.8",
    "@types/react-is": "^19",
    "@typescript-eslint/eslint-plugin": "7.18.0",
    "@typescript-eslint/parser": "7.18.0",
    "eslint": "8.57.0",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-eslint-comments": "3.2.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "5.1.3",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "eslint-plugin-sort-destructure-keys": "2.0.0",
    "eslint-plugin-storybook": "^10.3.5",
    "eslint-plugin-typescript-sort-keys": "3.3.0",
    "framer-motion": "10.16.15",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.0.0",
    "jest-coverage-badges": "^1.1.2",
    "jest-environment-jsdom": "^29.0.0",
    "lodash": "^4.18.1",
    "npm-run-all": "^4.1.5",
    "polished": "^4.3.1",
    "prettier": "3.1.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-is": "^18.3.1",
    "storybook": "^10.3.5",
    "ts-jest": "^29.4.0",
    "typescript": "5.5.4",
    "vite": "^7.3.2"
  }
}
